# =============================================================================
# MyCyber DLP — backend environment variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mycyber_dlp

# ---------------------------------------------------------------------------
# Auth / JWT
# Generate a strong secret with: python -c "import secrets; print(secrets.token_hex(32))"
# ---------------------------------------------------------------------------
JWT_SECRET_KEY=replace-with-long-random-string-min-32-chars
JWT_EXPIRE_HOURS=24

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# CORS (comma-separated list of allowed frontend origins)
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ---------------------------------------------------------------------------
# Scan limits
# ---------------------------------------------------------------------------
MAX_FILE_SIZE_MB=10.0
MAX_TEXT_LENGTH=50000
RATE_LIMIT_PER_MIN=60

# ---------------------------------------------------------------------------
# NER / ML model
# ---------------------------------------------------------------------------
NER_MODEL_NAME=dslim/bert-base-NER
NER_MIN_CONFIDENCE=0.85
USE_TRANSFORMER=true
MODEL_CACHE_DIR=/tmp/hf_models
