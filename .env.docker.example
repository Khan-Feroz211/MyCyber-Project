# =============================================================================
# MyCyber DLP — Docker environment template
# Copy this file to .env.docker and fill in real values.
# NEVER commit .env.docker to source control.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=choose-a-strong-password
POSTGRES_DB=mycyber_dlp

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-long-random-string-min-32-chars
JWT_EXPIRE_HOURS=24

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# Comma-separated list of allowed CORS origins (frontend URL)
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── ML / NER model ────────────────────────────────────────────────────────────
NER_MODEL_NAME=dslim/bert-base-NER
NER_MIN_CONFIDENCE=0.85
USE_TRANSFORMER=true

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=choose-a-strong-grafana-password

# ── Safepay Pakistan billing ──────────────────────────────────────────────────
SAFEPAY_SECRET_KEY=your-safepay-secret-key
SAFEPAY_WEBHOOK_SECRET=your-webhook-secret
FRONTEND_URL=http://localhost

# ── Email (choose one: SMTP or SendGrid) ─────────────────────────────────────
EMAIL_FROM=noreply@mycyber.pk
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password
# OR SendGrid:
SENDGRID_API_KEY=SG.xxxxxxxx
