[flake8]
exclude = 
    clean_get_next.py,
    fix_functions.py,
    apply_correct_fix.py,
    clean_version.py,
    create_fixed_app.py,
    find_dict_access.py,
    fix_get_next_user_id.py,
    test_fixed_registration.py,
    test_registration.py,
    __pycache__,
    .git,
    .venv,
    *.pyc,
    *.pyo,
    *.pyd,
    .Python,
    env,
    venv,
    ENV,
    env.bak,
    venv.bak
max-line-length = 120
ignore =
    E203,
    W503,
    E501,
    F821
